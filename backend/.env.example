APP_NAME=FastAPI Vue Login
API_PREFIX=/api
TOKEN_SECRET=change-this-local-secret
TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional PostgreSQL adapter URL. When set, the backend will use PostgreSQL
# for user lookup instead of the in-memory development repository.
# Example: postgresql://cv_app:change-me@localhost:5432/cv_app_db
DATABASE_URL=postgresql://postgres:123456@localhost:5432/cv_db
DEV_USER_ID=dev-user-1
DEV_USERNAME=admin
DEV_PASSWORD=admin123
DEV_DISPLAY_NAME=Development Admin
